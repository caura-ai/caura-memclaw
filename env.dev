# MemClaw OSS — Development defaults
# These are safe fallback values. To use real AI providers, create a .env file
# in this directory (see .env.example) and set your provider + API key there.
IS_STANDALONE=true
ENVIRONMENT=development
EMBEDDING_PROVIDER=fake
ENTITY_EXTRACTION_PROVIDER=fake
USE_LLM_FOR_MEMORY_CREATION=false
ALLOYDB_HOST=db
ALLOYDB_PORT=5432
ALLOYDB_USER=memclaw
ALLOYDB_PASSWORD=changeme
ALLOYDB_DATABASE=memclaw
ALLOYDB_REQUIRE_SSL=false
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Platform default providers (enterprise only — Caura's own API keys)
# When set, tenants without credentials get real LLM/embedding responses
# instead of FakeProvider. Leave empty for OSS self-hosted.
# PLATFORM_LLM_PROVIDER=vertex
# PLATFORM_LLM_MODEL=gemini-3.1-flash-lite-preview
# PLATFORM_LLM_API_KEY=
# PLATFORM_LLM_GCP_PROJECT_ID=
# PLATFORM_LLM_GCP_LOCATION=us-central1
# PLATFORM_EMBEDDING_PROVIDER=openai
# PLATFORM_EMBEDDING_API_KEY=
# PLATFORM_EMBEDDING_MODEL=text-embedding-3-small
# PLATFORM_EMBEDDING_GCP_PROJECT_ID=
# PLATFORM_EMBEDDING_GCP_LOCATION=
